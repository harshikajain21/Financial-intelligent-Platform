FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY dashboard/package*.json ./
RUN npm install

# Copy source
COPY dashboard/ .

# Build production build
RUN npm run build

# Serve with nginx
FROM nginx:alpine
COPY --from=0 /app/build /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]